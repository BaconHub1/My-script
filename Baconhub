local loadstring = loadstring or load

local request = syn and syn.request 
    or (http and http.request) 
    or http_request 
    or request

local function httpget(url)
    if request then
        local success, response = pcall(function()
            return request({
                Url = url,
                Method = "GET"
            })
        end)
        
        if success and response and response.Body then
            return response.Body
        end
    end
    
    local success, result = pcall(function()
        return game:HttpGet(url)
    end)
    
    if success then
        return result
    end
    
    return nil
end

pcall(function()
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "BaconHub",
        Text = "BaconHub is back! Big thanks to blaketheflake 🐐",
        Duration = 6
    })
end)
local scriptUrl = "https://pastefy.app/hUWy8JZW/raw"
local scriptCode = httpget(scriptUrl)

if scriptCode and scriptCode ~= "" then
    local success, err = pcall(function()
        loadstring(scriptCode)()
    end)
    
    if not success then
        warn("BaconHub failed to execute: " .. tostring(err))
    end
else
    warn("Failed to fetch BaconHub script from: " .. scriptUrl)
end
